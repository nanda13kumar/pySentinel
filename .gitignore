# ==============================================================================
#  PySentinel — .gitignore
# ==============================================================================

# ── Scan output ────────────────────────────────────────────────────────────────
# Generated by pysentinel.sh — never commit scan reports
reports/
pysentinel_reports/
*.report.txt
*.report.html

# ── Python ─────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments (host-mode runs create these in /tmp, but just in case)
.venv/
venv/
env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# ── Docker ─────────────────────────────────────────────────────────────────────
# Locally built images don't belong in git — pull from ECR instead
# (no Docker artefacts are generated in the repo, this is precautionary)
*.tar          # docker save output
*.tar.gz       # compressed image exports

# ── Secrets & environment ──────────────────────────────────────────────────────
# NEVER commit credentials, tokens, or local overrides
.env
.env.*
!.env.example   # allow the example template to be committed
*.pem
*.key
*.p12
*.pfx
secrets.json
credentials.json

# ── macOS ──────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ── Linux ──────────────────────────────────────────────────────────────────────
*~
.nfs*

# ── Windows ────────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini

# ── IDE & editors ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.project
.classpath

# ── Logs ───────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Temp scan artefacts ────────────────────────────────────────────────────────
# pysentinel.sh writes to /tmp/pysentinel_* and cleans up via trap,
# but guard against any leftovers being accidentally staged
/tmp/
*.tmp